      "pinPadMapping": {},
      "pythonCode": "class SmartSignal:\n    def update(self, t, inputs):\n        return inputs.get('In1', 0.0)",
      "fluxCode": "def update(t, inputs) {\n    let freq = 1000.0;\n    let duty = V(\"In1\") / 5.0;\n    if (duty < 0.0) {\n        duty = 0.0;\n    }\n    if (duty > 1.0) {\n        duty = 1.0;\n    }\n    let ramp = (t * freq) - floor(t * freq);\n    if (ramp < duty) {\n        return 5.0;\n    }\n    return 0.0;\n}",
      "engineType": "flux",
      "inputs": [
        "In1"
      ],
      "outputs": [
        "Out1"
      ],
